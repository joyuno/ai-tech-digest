---
layout: null
---
[
  {% for post in site.posts %}
  {% assign sub_chunks = post.content | split: '<span class="sub-tag">' %}
  {% capture _all_kws %}{% for c in sub_chunks %}{% unless forloop.first %}{{ c | split: '</span>' | first | replace: '#', '' | strip }}{% unless forloop.last %}||{% endunless %}{% endunless %}{% endfor %}{% endcapture %}
  {
    "title": {{ post.title | jsonify }},
    "url": {{ post.url | relative_url | jsonify }},
    "date": "{{ post.date | date: '%Y.%m.%d' }}",
    "iso": "{{ post.date | date: '%Y-%m-%d' }}",
    "image": {{ post.daily_image | default: "" | jsonify }},
    "source": {{ post.daily_source | default: "" | jsonify }},
    "daily_title": {{ post.daily_title | default: post.title | jsonify }},
    "daily_url": {{ post.daily_url | default: post.url | jsonify }},
    "keywords": {% if post.daily_keywords %}{{ post.daily_keywords | jsonify }}{% else %}[]{% endif %},
    "all_keywords": {% if sub_chunks.size > 1 %}{{ _all_kws | split: '||' | jsonify }}{% else %}[]{% endif %}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
