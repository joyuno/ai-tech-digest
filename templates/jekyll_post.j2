---
layout: post
title: "{{ headline if headline else 'AI Tech - ' + date }}"
date: {{ date }}
categories: [AI, Tech]
tags: [AI, LLM, 트렌드, 기술블로그]
---

{% set src_icon = {
  '📚': 'book-open',
  '🤗': 'cpu',
  '⭐': 'star',
  '💳': 'credit-card',
  '👕': 'shirt',
  '📰': 'newspaper',
  '🐦': 'at-sign'
} %}
{% set cat_icon = {
  '🧠': 'brain',
  '🔧': 'wrench',
  '🎯': 'target',
  '🔍': 'search',
  '🤖': 'bot',
  '💻': 'code-2'
} %}

{% for source in sources %}
## <i data-lucide="{{ src_icon[source.emoji] | default('hash') }}"></i> {{ source.name }}

{% for item in source["items"] %}
<div class="digest-item" markdown="1">

<h3><a href="{{ item.url }}" target="_blank">{{ item.title }}</a></h3>

{% if item.categories %}
<div class="categories">
{% for cat in item.categories %}<span class="category-tag"><i data-lucide="{{ cat_icon[cat.emoji] | default('hash') }}"></i> {{ cat.name }}</span> {% endfor %}
</div>
{% endif %}

{{ item.summary }}

{% if item.author %}<small><i data-lucide="user"></i> {{ item.author }}</small>{% endif %}

</div>

{% endfor %}

---

{% endfor %}

